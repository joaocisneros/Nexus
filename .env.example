# AI Services (configure when ready)
# OPENAI_API_KEY is read by main process only (not exposed to renderer)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OLLAMA_HOST=http://localhost:11434

# gitlawb OpenGateway (compatible with OpenAI API)
OPENGATEWAY_API_KEY=ogw_live_your_key_here
OPENGATEWAY_URL=https://opengateway.gitlawb.com/v1
OPENGATEWAY_MODEL=mimo-v2-pro

# Vite renderer config (subset of above, exposed to browser)
VITE_OPENAI_MODEL=gpt-4
VITE_OLLAMA_HOST=http://localhost:11434


# Development
NODE_ENV=development
PORT=3000

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_LOCAL_AI=true
ENABLE_TERMINAL=true

# UI Settings
THEME=dark
LANGUAGE=es

# Analytics (optional)
DISABLE_TELEMETRY=true